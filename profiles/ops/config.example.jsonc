{
  "agents": {
    "defaults": {
      "sandbox": {
        "workspaceAccess": "ro"
      },
      "heartbeat": {
        "every": "15m",
        "target": "none",
        "lightContext": true,
        "isolatedSession": true
      },
      "params": {
        "cacheRetention": "short"
      }
    }
  }
}
